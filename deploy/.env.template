# alfred-coo-svc environment configuration
# Copy to /etc/alfred-coo/.env and chmod 0600
# All secrets pulled at startup from GCP Secret Manager when ADC is available.

# Soul service (memory + mesh tasks)
SOUL_API_URL=http://100.105.27.63:8080
SOUL_API_URLS=http://100.105.27.63:8080,https://soul-svc-1006583428928.us-central1.run.app
SOUL_API_KEY=  # set via Secret Manager: soul-api-key
SOUL_SESSION_ID=alfred-coo
SOUL_NODE_ID=oracle
SOUL_HARNESS=alfred-coo-svc

# Model providers
ANTHROPIC_API_KEY=  # set via Secret Manager: anthropic-api-key
OPENROUTER_API_KEY=  # set via Secret Manager: openrouter-api-key
OLLAMA_URL=http://172.17.0.1:8185/v1

# Daemon behavior
MESH_POLL_INTERVAL_SECONDS=30
HEALTH_PORT=8090
LOG_LEVEL=INFO
LOG_FORMAT=json

# Slack escalation
SLACK_BOT_TOKEN=  # set via Secret Manager: alfred-slack-bot-token
