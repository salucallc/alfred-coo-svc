# Mission Control Appliance — environment template
# Copy to .env in this directory before `docker compose up -d`.
# Required vars MUST be set; marked (required). Secrets must not be checked in.

# ── Host ─────────────────────────────────────────────────────────────────────
# FQDN the appliance will answer on (used by Caddy for ACME + open-webui link).
# Use "localhost" for local dev; a real FQDN to get Let's Encrypt TLS.
APPLIANCE_HOSTNAME=localhost

# ── Postgres ─────────────────────────────────────────────────────────────────
# (required) — no default; container refuses to start without it.
# Generate: `python -c "import secrets;print(secrets.token_urlsafe(32))"`
POSTGRES_PASSWORD=

# ── soul-svc bootstrap ───────────────────────────────────────────────────────
# (required) — root API key used to mint per-tenant keys during first-boot wizard.
# Generate: `python -c "import secrets;print('sk_soul_root_'+secrets.token_urlsafe(32))"`
SOUL_API_KEY_ROOT=

# ── COO Daemon ───────────────────────────────────────────────────────────────
# (required) — API key for the COO daemon to authenticate with soul-svc.
# After the first-boot wizard completes, mint a key: POST /v1/keys/mint to soul-svc.
# For initial setup use the root key; rotate to a scoped key after wizard finishes.
SOUL_API_KEY=

# ── Ollama ───────────────────────────────────────────────────────────────────
# Where the appliance should send inference requests. The default assumes Ollama
# runs on the Docker host. For a remote Ollama server, set its URL (reachable
# from inside the appliance network).
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── MCP Tools ────────────────────────────────────────────────────────────────
# GitHub Personal Access Token — used by COO daemon + mcp-github service.
# Required scopes: repo, read:org, workflow
GITHUB_TOKEN=

# Slack xoxb bot token — used by COO daemon + mcp-slack service.
# Create at https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=

# Slack workspace/team ID (starts with T) — required for mcp-slack.
SLACK_TEAM_ID=

# Linear API key — used by COO daemon + mcp-linear service.
# Create at https://linear.app/settings/api
LINEAR_API_KEY=

# Notion integration token — used by mcp-notion service.
# Create at https://www.notion.so/my-integrations
NOTION_API_KEY=

# ── Optional: behaviour toggles ──────────────────────────────────────────────
# Admission middleware — keep DRY_RUN=true until you have tuned the K/window for
# your traffic shape. The middleware logs what it WOULD block but takes no action.
SPARSE_K_DRY_RUN=true
SPARSE_K=32
SPARSE_K_WINDOW_SECONDS=60

# CoT capture — path on the soul-svc volume where JSONL transcripts are appended.
SOUL_COT_SINK=/var/lib/soul-svc/cot/cot.jsonl
