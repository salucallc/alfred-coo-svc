# Caddyfile for Mission Control Appliance
# APE/V: SAL-2636 – see D_ops_layer.md
# Routes internal services under a single hostname with path-based routing.
# MCP services are routed per-service; /soul/* → soul-svc; /chat/* → open-webui.

{$APPLIANCE_HOSTNAME:localhost} {

  handle /healthz {
    respond "ok" 200
  }

  handle /soul/* {
    uri strip_prefix /soul
    reverse_proxy soul-svc:8080
  }

  handle /mcp/github/* {
    uri strip_prefix /mcp/github
    reverse_proxy mcp-github:8203
  }

  handle /mcp/slack/* {
    uri strip_prefix /mcp/slack
    reverse_proxy mcp-slack:8201
  }

  handle /mcp/linear/* {
    uri strip_prefix /mcp/linear
    reverse_proxy mcp-linear:8208
  }

  handle /mcp/notion/* {
    uri strip_prefix /mcp/notion
    reverse_proxy mcp-notion:8212
  }

  handle_path /chat* {
    reverse_proxy open-webui:8080
  }

  # New ops routes per OPS-03
  handle /ops/* {
    forward_auth http://authelia:9091/api/verify?rd=%{uri}
    uri strip_prefix /ops
    reverse_proxy grafana:3000
  }

  handle /auth/* {
    uri strip_prefix /auth
    reverse_proxy authelia:9091
  }

  handle /vault/* {
    uri strip_prefix /vault
    reverse_proxy infisical:8080
  }

  handle {
    reverse_proxy alfred-portal:3000
  }
}