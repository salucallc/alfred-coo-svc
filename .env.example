# .env.example — required environment for `docker compose up` at repo root.
# Copy to .env and fill in actual values. .env is gitignored.
#
# This list mirrors the keys consumed by src/alfred_coo/config.py +
# the GHCR image entrypoint. The full canonical reference is the
# Oracle host file /etc/alfred-coo/.env.

# --- soul-svc (memory graph) ---
SOUL_API_URL=http://100.105.27.63:8080
SOUL_API_URLS=http://100.105.27.63:8080,https://soul-svc-1006583428928.us-central1.run.app
SOUL_API_KEY=
SOUL_SESSION_ID=alfred-coo
SOUL_NODE_ID=oracle
SOUL_HARNESS=alfred-coo-svc

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- gateway (alfred-chat-stack) ---
OLLAMA_URL=http://172.17.0.1:8185/v1
GATEWAY_URL=http://172.17.0.1:8185
AUTOBUILD_SOULKEY=
TIRESIAS_TENANT=alfred-coo-mc

# --- mesh + scheduler ---
MESH_POLL_INTERVAL_SECONDS=30
HEALTH_PORT=8090
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- integrations ---
SLACK_BOT_TOKEN=
SLACK_BATCAVE_CHANNEL=C0ASAKFTR1C
LINEAR_API_KEY=
GITHUB_TOKEN=

# --- budget guard ---
DAILY_BUDGET_USD=200.0

# --- compose-specific ---
# Image tag override (default: latest). Pin to sha-<short> for reproducible deploys.
ALFRED_COO_TAG=latest
# Host port for the sidecar deploy (default: 8091). Container always serves on 8090.
ALFRED_COO_HEALTH_PORT_HOST=8091
# Host directory for /var/lib/alfred-coo bind mount (default: ./state).
ALFRED_COO_STATE_DIR=./state
