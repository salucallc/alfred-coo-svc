; Local secrets for the Alfred voice puck firmware (SAL-4006).
;
; Copy this file to `secrets.ini` next to platformio.ini and fill in the
; real values. `secrets.ini` is .gitignore'd; do NOT commit it.
;
; PlatformIO loads this file because platformio.ini has
;   extra_configs = secrets.ini
; and the Wi-Fi + WebSocket build_flags below are pulled into the
; default `[env:arduino]` environment via:
;   build_flags = ${secrets.build_flags}
;
; Schema:
;   ALFRED_WIFI_SSID         - primary Wi-Fi SSID the puck should join.
;   ALFRED_WIFI_PASSWORD     - password for the primary SSID.
;   ALFRED_WIFI_SSID_2       - (optional) secondary SSID. WiFiMulti picks
;                              whichever AP has the strongest signal.
;   ALFRED_WIFI_PASSWORD_2   - (optional) password for the secondary SSID.
;   ALFRED_GATEWAY_HOST      - hostname or IP of the alfred-coo-svc-hawkman
;                              fleet_voice gateway. For the SAL-4006 smoke
;                              this is the minipc's LAN IP, e.g. 192.168.12.134.
;   ALFRED_GATEWAY_PORT      - TCP port the gateway listens on. Default 8091.
;   ALFRED_GATEWAY_PATH      - WS path. Default /v1/fleet/voice.
;   ALFRED_GATEWAY_BEARER    - bearer token for the gateway's FLEET_VOICE_KEY.
;                              For the smoke we set both sides to a fixed
;                              dev value such as `dev-key-001`. Per-device
;                              JWT lands in SAL-4017.
;   ALFRED_GATEWAY_TLS       - 0 for plain ws://, 1 for wss:// (TLS lands later).
;   ALFRED_BOOT_TEST_TONE_HZ - (optional, debug) emit a 2 s sine-wave tone
;                              at this frequency through the I2S TX path
;                              at boot. Validates speaker / earphone-jack
;                              chain without needing WiFi / gateway. Set
;                              to 880 for an audible test tone; omit to
;                              disable in production.
;
; All values are quoted with embedded \" so the C preprocessor sees a
; proper string literal.

[secrets]
build_flags =
  -D ALFRED_WIFI_SSID=\"my-ssid\"
  -D ALFRED_WIFI_PASSWORD=\"my-password\"
  ; Optional secondary AP. Comment out if not needed.
  -D ALFRED_WIFI_SSID_2=\"my-secondary-ssid\"
  -D ALFRED_WIFI_PASSWORD_2=\"my-secondary-password\"
  -D ALFRED_GATEWAY_HOST=\"192.168.12.134\"
  -D ALFRED_GATEWAY_PORT=8091
  -D ALFRED_GATEWAY_PATH=\"/v1/fleet/voice\"
  -D ALFRED_GATEWAY_BEARER=\"dev-key-001\"
  -D ALFRED_GATEWAY_TLS=0
  ; Uncomment to emit a 880 Hz sine-wave tone at boot through I2S TX.
  ; Useful for verifying the speaker / earphone-jack chain after
  ; flashing on a fresh carrier. Disabled in production.
  ; -D ALFRED_BOOT_TEST_TONE_HZ=880
