# .dockerignore — keep build context lean.
# The Dockerfile uses a multi-stage build that only consumes
# pyproject.toml + README.md + LICENSE + src/. Everything else is noise.

# VCS / GH metadata
.git
.github
.gitignore
.gitattributes

# Python build / cache
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build
develop-eggs
dist
downloads
eggs
.eggs
sdist
var
wheels
*.egg-info
*.egg
.installed.cfg

# Virtualenvs
.env
.env.local
.venv
venv
ENV

# Test / lint caches
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov

# Editor + OS
.vscode
.idea
*.swp
.DS_Store
Thumbs.db

# Project artifacts not needed at runtime
# (Dockerfile COPY explicitly pulls pyproject.toml, README.md, LICENSE, and src/.)
plans
tests
docs
deploy
configs
scripts
aletheia
*.log
*.bak
