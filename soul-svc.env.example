# soul-svc.env.example
#
# Copy to soul-svc.env and fill in real values. Loaded by the soul-svc
# service in docker-compose.yml. .env files are gitignored.
#
# Reference: GSM (cgtuoiggcngldtzfqosm project) holds the canonical
# values for the Saluca production tenant. Pull with:
#   gcloud secrets versions access latest --project=cgtuoiggcngldtzfqosm \
#     --secret=SOUL_SUPABASE_URL
# (and similar for other secrets below).

# --- Supabase backend ---
# Project: cgtuoiggcngldtzfqosm (https://supabase.com/dashboard).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- soul-svc shared key ---
# Used by clients (alfred-coo, mesh harnesses, etc.) for Bearer auth
# against /v1/* endpoints. Must match SOUL_API_KEY in alfred-coo.env.
SOUL_API_KEY=

# --- crypto / identity (optional) ---
# When set, soul-svc enables the persona signature verification path.
# Leave blank for boot-locally / non-prod use.
PERSONA_VERIFY_KEY=

# --- billing (optional, prod only) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- crypto payments (optional, prod only) ---
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# --- runtime knobs ---
PORT=8080
LOG_LEVEL=INFO

# --- compose-specific overrides ---
SOUL_SVC_TAG=latest
SOUL_PORT=8080
