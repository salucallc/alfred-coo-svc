# alfred-coo.env.example
#
# Copy to alfred-coo.env and fill in real values. Loaded by the alfred-coo
# service in docker-compose.yml. .env files are gitignored.
#
# Reference: src/alfred_coo/config.py + the systemd-managed copy at
# /etc/alfred-coo/.env on Oracle. Keep both in sync.

# --- soul-svc (memory graph) ---
# In the compose bundle the daemon talks to the in-stack soul-svc on the
# docker network. SOUL_API_URLS is the failover chain (JSON-encoded list,
# the way pydantic-settings v2 parses List[str] from env). Leave it
# commented out to use the in-process default chain (Oracle + Cloud Run).
SOUL_API_URL=http://soul-svc:8080
# SOUL_API_URLS=["http://soul-svc:8080","http://100.105.27.63:8080","https://soul-svc-1006583428928.us-central1.run.app"]
SOUL_API_KEY=
SOUL_SESSION_ID=alfred-coo
SOUL_NODE_ID=local
SOUL_HARNESS=alfred-coo-svc

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_KEY=

# --- gateway (alfred-chat-stack) ---
OLLAMA_URL=http://172.17.0.1:8185/v1
GATEWAY_URL=http://172.17.0.1:8185
AUTOBUILD_SOULKEY=
TIRESIAS_TENANT=alfred-coo-mc

# --- mesh + scheduler ---
MESH_POLL_INTERVAL_SECONDS=30
HEALTH_PORT=8090
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- integrations ---
# Slack: prefer the Alfred-scoped token (canonical name from
# reference_credential_vault_map). Legacy SLACK_BOT_TOKEN still consulted
# for back-compat with the systemd unit's .env.
SLACK_BOT_TOKEN=
SLACK_BOT_TOKEN_ALFRED=
SLACK_BATCAVE_CHANNEL=C0ASAKFTR1C
LINEAR_API_KEY=
ALFRED_OPS_LINEAR_API_KEY=
GITHUB_TOKEN=

# --- budget guard ---
DAILY_BUDGET_USD=200.0

# --- compose-specific overrides ---
# Image tag override (default: latest). Pin to sha-<short> for reproducible
# deploys, or branch-<branch> to track an in-flight feature line.
ALFRED_COO_TAG=latest
# Host port the daemon serves on (default: 8091). Container always
# listens on 8090; this value is host-side only.
ALFRED_COO_PORT=8091
